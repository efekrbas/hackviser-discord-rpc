{
    "manifest_version": 3,
    "name": "Hackviser Discord RPC",
    "version": "1.0.0",
    "description": "Hackviser Discord Rich Presence (Electron Bridge)",
    "permissions": [
        "tabs",
        "alarms"
    ],
    "host_permissions": [
        "*://*.hackviser.com/*",
        "*://hackviser.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon48.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.hackviser.com/*",
                "*://hackviser.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ]
}