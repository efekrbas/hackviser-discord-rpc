{
  "name": "hackviser-discord-rpc",
  "version": "2.0.0",
  "description": "Hackviser Discord Rich Presence Client",
  "main": "main.js",
  "scripts": {
    "start": "node launcher.js",
    "build": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "discord",
    "rpc",
    "hackviser",
    "cybersecurity",
    "electron"
  ],
  "author": "Hackviser",
  "license": "MIT",
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.hackviser.discord-rpc",
    "productName": "Hackviser RPC",
    "win": {
      "target": "nsis",
      "icon": "images/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "HackviserRPC_Setup.exe",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "installerIcon": "images/icon.ico",
      "uninstallerIcon": "images/icon.ico",
      "uninstallDisplayName": "Hackviser RPC"
    },
    "files": [
      "main.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "config.json",
      "images/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "config.json",
        "to": "config.json"
      }
    ]
  }
}